# ─── Transkripin Backend Configuration ─────────────────────────────
# Salin file ini menjadi `.env` lalu sesuaikan nilainya.

# faster-whisper model size: tiny | base | small | medium | large-v3
MODEL_SIZE=base

# Device: cpu | cuda
DEVICE=cpu

# Compute precision:
#   CPU  → int8 (default), int8_float32, float32
#   GPU  → float16, int8_float16
COMPUTE_TYPE=int8

# Batas ukuran upload (MB)
MAX_UPLOAD_MB=100

# Batas durasi audio (menit)
MAX_AUDIO_DURATION_MINUTES=60

# Timeout proses transkripsi (detik)
TRANSCRIBE_TIMEOUT_SECONDS=1800

# Comma-separated origins yang diizinkan CORS
CORS_ORIGINS=http://localhost:3000

# Atau gunakan regex untuk men-cover banyak subdomain (mis. Vercel preview)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app|https://.*\.app\.github\.dev

# (opsional) Direktori cache model. Kosongkan untuk default HuggingFace.
# MODEL_CACHE_DIR=/data/models

# (opsional) Direktori temp untuk upload audio
# TMP_DIR=/tmp/transkripin
